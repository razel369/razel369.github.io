# Binance API keys — NEVER commit real keys
BINANCE_API_KEY=
BINANCE_API_SECRET=

# true = no real orders (default). Set false only when ready.
DRY_RUN=true

# Use Binance Futures testnet when true (recommended before live)
USE_TESTNET=true

# true = no network; synthetic candles (local demo if Binance is geo-blocked)
FORCE_OFFLINE=false
DEMO_EQUITY=100
# true = one cycle then exit (good for smoke tests)
RUN_ONCE=false

# Trading
SYMBOL=BTC/USDT:USDT
TIMEFRAME=15m
LEVERAGE=3
RISK_PER_TRADE_PCT=8
MAX_DAILY_TRADES=3
MAX_DRAWDOWN_PCT=30
TAKE_PROFIT_R=2.0
ATR_PERIOD=14
ATR_STOP_MULT=1.5
BREAKOUT_LOOKBACK=20
MIN_QUOTE_BALANCE=5
POLL_SECONDS=30
